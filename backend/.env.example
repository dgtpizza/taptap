# --- Required ---
MONGODB_URI=mongodb://localhost:27017
BOT_TOKEN=replace-with-telegram-bot-token

# --- Optional (defaults shown) ---
PORT=3000
LOG_LEVEL=info
MONGODB_DB=cryptoclicker
# CORS_ORIGIN=https://your-app.pages.dev

# Tuning (override only if needed)
# BODY_LIMIT_BYTES=4096
# SHUTDOWN_DELAY_MS=1000
# PROFILE_SYNC_MS=60000               # how often a user's Telegram profile is re-synced
# CLICK_RATE_LIMIT_MS=250             # min gap between accepted click batches per user
# LEADERBOARD_RATE_LIMIT_MS=1000      # min gap between leaderboard reads per user
# MONGODB_MAX_POOL_SIZE=20
# MONGODB_MIN_POOL_SIZE=2
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGODB_SOCKET_TIMEOUT_MS=45000
