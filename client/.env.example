# Раздельный деплой — URL API. В локальной разработке оставить пустым:
# Vite проксирует /api на http://127.0.0.1:3000.
VITE_API_URL=
# Локальная разработка вне Telegram — заранее подписанный initData (иначе сервер вернёт 401).
# Создать: BOT_TOKEN=<same-as-backend> npm --prefix backend run dev:init-data
VITE_DEV_INIT_DATA=
